  {
    "id": "TC015",
    "title": "Build a simple custom workout and start/pause playback",
    "description": "Verifies a user can add exercise and rest blocks, start the workout, see the timer/timeline, and pause/resume.",
    "category": "Custom Timer Builder Mode",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "action",
        "description": "Click Segmented Control \"Custom\" tab"
      },
      {
        "type": "action",
        "description": "Click Add Exercise button"
      },
      {
        "type": "action",
        "description": "Type \"Push-ups\" into the Name input for a given block"
      },
      {
        "type": "action",
        "description": "Type \"30\" into the Duration (seconds) for an exercise block"
      },
      {
        "type": "action",
        "description": "Click \"Start Workout\" arrow to compile the blocks into a sequence and start execution"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Circular Timer\" is visible"
      },
      {
        "type": "action",
        "description": "Click \"Start/Pause\" pill button"
      }
    ]
  },
