  {
    "id": "TC008",
    "title": "Run a preset workout and verify countdown + timeline visuals appear",
    "description": "Verifies a user can select a preset template, start it, and see the circular countdown and workout timeline during playback.",
    "category": "Preset Timer Mode",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to \"/\""
      },
      {
        "type": "action",
        "description": "Click Segmented Control \"Presets\" tab"
      },
      {
        "type": "action",
        "description": "Scroll through carousel of predefined workout templates"
      },
      {
        "type": "action",
        "description": "Click a template card to select it"
      },
      {
        "type": "action",
        "description": "Click \"Start [Template Name]\" to begin the compiled workout queue"
